<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape driving UI: Left joystick | HUD | Right joystick -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E">

    <!-- ===== LEFT joystick (forward/back) ================== -->
    <com.rover.app.ui.JoystickView
        android:id="@+id/joystickLeft"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp" />

    <!-- ===== RIGHT joystick (rotation) ===================== -->
    <com.rover.app.ui.JoystickView
        android:id="@+id/joystickRight"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp" />

    <!-- ===== Center HUD ==================================== -->
    <LinearLayout
        android:id="@+id/hudLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintStart_toEndOf="@id/joystickLeft"
        app:layout_constraintEnd_toStartOf="@id/joystickRight"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Transport indicator -->
        <TextView
            android:id="@+id/txtTransport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BLE ▪ Rover"
            android:textColor="#88CCFF"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <!-- Telemetry row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txtVolt"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="0.0 V"
                android:textColor="#FFD700"
                android:gravity="center"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtCurr"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="0.0 A"
                android:textColor="#90EE90"
                android:gravity="center"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtTemp"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="0°C"
                android:textColor="#FFA07A"
                android:gravity="center"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtEnc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="L:0  R:0"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:layout_marginBottom="16dp" />

        <!-- Action buttons -->
        <Button
            android:id="@+id/btnEstop"
            android:layout_width="120dp"
            android:layout_height="56dp"
            android:text="E-STOP"
            android:backgroundTint="#CC0000"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnHorn"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:text="📯"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnCameras"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:text="📷"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnOta"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:text="⬆ FW" />
        </LinearLayout>

        <Button
            android:id="@+id/btnDisconnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disconnect"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
