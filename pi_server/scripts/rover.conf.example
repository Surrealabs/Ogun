# ============================================================
#  Rover Configuration File
#  /etc/rover/rover.conf
#  Lines starting with # are comments.
# ============================================================

# --- Teensy USB serial bridge ---
# Find the port with: ls /dev/ttyACM*
teensy_port    = /dev/ttyACM0
serial_baud    = 115200

# Push Teensy firmware runtime configuration at boot (true/false)
teensy_push_fw_config = true

# Teensy firmware motor/encoder pin map (digital pins, Teensy 4.1 terminal breakout)
teensy_l_rpwm_pin = 20
teensy_l_lpwm_pin = 21
teensy_l_en_pin   = 22
teensy_r_rpwm_pin = 16
teensy_r_lpwm_pin = 17
teensy_r_en_pin   = 18
teensy_t_rpwm_pin = 24
teensy_t_lpwm_pin = 25
teensy_t_en_pin   = 26
teensy_enc_la_pin = 2
teensy_enc_lb_pin = 3
teensy_enc_ra_pin = 4
teensy_enc_rb_pin = 5

# Teensy analog sensor pin map
teensy_vbat_adc_pin = 14
teensy_curr_l_adc_pin = 23
teensy_curr_r_adc_pin = 19
teensy_curr_t_adc_pin = 27
teensy_temp_adc_pin = 23

# Teensy sensor calibration + timings
teensy_vbat_div_ratio = 4.03
teensy_curr_zero_mv = 0.0
teensy_curr_sens_mv_per_a = 8.5

# Teensy drive behavior tuning (simple model)
# Max PWM ceiling (0-255)
teensy_max_pwm = 255
# Start PWM floor when moving (overcomes static friction, 0-255)
teensy_min_pwm = 0
# Ramp time: seconds to accelerate from 0 to full power
teensy_ramp_sec = 1.0
# Motor direction inversion (for mirror-mounted motors)
invert_left_motor = false
invert_right_motor = true

teensy_watchdog_ms = 500
teensy_telem_interval_ms = 100

# --- BLE ---
ble_name       = Rover
# Use "hci0" unless you have multiple Bluetooth adapters
ble_device     = hci0

# --- WiFi control ---
ws_port        = 9000

# --- Web UI (browser control panel, also used by veve app) ---
webui_port     = 8080
webui_dir      = /opt/rover/webui

# --- Cameras (V4L2) ---
# ls /dev/video* to discover devices
cam0_device    = /dev/video0
cam1_device    = /dev/video2
cam0_port      = 8081
cam1_port      = 8082
cam_width      = 640
cam_height     = 480
cam_fps        = 15
# JPEG quality 0-100 (higher = better quality but more bandwidth)
cam_jpeg_quality = 80

# --- Drive parameters ---
# Maximum motor speed sent to Teensy (0.0 - 1.0)
max_motor_speed = 1.0
# Joystick dead zone (values smaller than this are treated as 0)
deadband        = 0.05

# --- Telemetry ---
# How many times per second to poll Teensy for sensor data
telemetry_hz    = 10

# --- Audio playback ---
audio_device   = default
audio_dir      = /opt/rover/sounds

# --- Teensy OTA flashing ---
# Path to teensy_loader_cli (installed by install.sh)
ota_flash_cmd  = /usr/local/bin/teensy_loader_cli
# Your Teensy model: TEENSY40, TEENSY41, TEENSY36, TEENSYLC ...
teensy_mmcu    = TEENSY41
