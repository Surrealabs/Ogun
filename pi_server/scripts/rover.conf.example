# ============================================================
#  Rover Configuration File
#  /etc/rover/rover.conf
#  Lines starting with # are comments.
# ============================================================

# --- Teensy USB serial bridge ---
# Find the port with: ls /dev/ttyACM*
teensy_port    = /dev/ttyACM0
serial_baud    = 115200

# Push Teensy firmware runtime configuration at boot (true/false)
teensy_push_fw_config = true

# Teensy firmware motor/encoder pin map (digital pins)
teensy_l_rpwm_pin = 21
teensy_l_lpwm_pin = 19
teensy_l_en_pin   = 18
teensy_r_rpwm_pin = 22
teensy_r_lpwm_pin = 23
teensy_r_en_pin   = 16
teensy_enc_la_pin = 8
teensy_enc_lb_pin = 9
teensy_enc_ra_pin = 10
teensy_enc_rb_pin = 11

# Teensy analog sensor pin map
teensy_vbat_adc_pin = 14
teensy_curr_adc_pin = 17
teensy_temp_adc_pin = 20

# Teensy sensor calibration + timings
teensy_vbat_div_ratio = 4.03
teensy_curr_zero_mv = 1650.0
teensy_curr_sens_mv_per_a = 66.0

# Teensy drive behavior tuning (firmware-side safety)
# Reduce these for safer indoor testing.
# 0.0-1.0 caps:
teensy_drive_max_fwd = 0.60
teensy_drive_max_rev = 0.45
teensy_turn_max = 0.50
# Expo > 1 softens low-stick response, keeping top-end available.
teensy_throttle_expo = 1.40
teensy_turn_expo = 1.55
# Slew rates in normalized speed/second; lower = slower PWM ramp.
teensy_accel_up_per_s = 1.20
teensy_accel_down_per_s = 2.20
invert_left_motor = false
invert_right_motor = false

teensy_watchdog_ms = 500
teensy_telem_interval_ms = 100

# --- BLE ---
ble_name       = Rover
# Use "hci0" unless you have multiple Bluetooth adapters
ble_device     = hci0

# --- WiFi control ---
ws_port        = 9000

# --- Web UI (browser control panel, also used by veve app) ---
webui_port     = 8080
webui_dir      = /opt/rover/webui

# --- Cameras (V4L2) ---
# ls /dev/video* to discover devices
cam0_device    = /dev/video0
cam1_device    = /dev/video2
cam0_port      = 8081
cam1_port      = 8082
cam_width      = 640
cam_height     = 480
cam_fps        = 30
# JPEG quality 0-100 (higher = better quality but more bandwidth)
cam_jpeg_quality = 80

# --- Drive parameters ---
# Maximum motor speed sent to Teensy (0.0 - 1.0)
max_motor_speed = 1.0
# Joystick dead zone (values smaller than this are treated as 0)
deadband        = 0.05

# --- Telemetry ---
# How many times per second to poll Teensy for sensor data
telemetry_hz    = 10

# --- Audio playback ---
audio_device   = default
audio_dir      = /opt/rover/sounds

# --- Teensy OTA flashing ---
# Path to teensy_loader_cli (installed by install.sh)
ota_flash_cmd  = /usr/local/bin/teensy_loader_cli
# Your Teensy model: TEENSY40, TEENSY41, TEENSY36, TEENSYLC ...
teensy_mmcu    = TEENSY40
